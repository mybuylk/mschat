rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048))
        && data.online is bool;
    }

    // Collection matches
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }
    
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if isSignedIn() 
        && request.resource.data.from == request.auth.uid 
        && request.resource.data.to is string
        && (request.resource.data.text == null || (request.resource.data.text is string && request.resource.data.text.size() <= 100000))
        && request.resource.data.read == false;
      allow update: if isSignedIn() 
        && request.resource.data.from == resource.data.from
        && request.resource.data.to == resource.data.to
        && (
          (resource.data.to == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'isViewOnceOpened', 'isStarred', 'text', 'fileURL', 'fileType', 'fileName', 'reactions'])) ||
          (resource.data.from == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'fileURL', 'fileType', 'fileName', 'isDeleted', 'isEdited', 'isStarred', 'reactions']))
        );
      allow delete: if isSignedIn() && resource.data.from == request.auth.uid;
    }
    
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() 
        && (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
    }
  }
}
